{
    "schemes": [
        "http",
        "https"
    ],
    "swagger": "2.0",
    "info": {
        "description": "API de disponibilite des salles campus (buildings, rooms, schedules, health).",
        "title": "Campus Room Status API",
        "contact": {},
        "version": "1.0"
    },
    "basePath": "/",
    "paths": {
        "/api/v1/auth/google/callback": {
            "get": {
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "auth"
                ],
                "summary": "Handle Google OAuth callback",
                "parameters": [
                    {
                        "type": "string",
                        "description": "OAuth state",
                        "name": "state",
                        "in": "query",
                        "required": true
                    },
                    {
                        "type": "string",
                        "description": "OAuth authorization code",
                        "name": "code",
                        "in": "query",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "$ref": "#/definitions/api.ErrorEnvelope"
                        }
                    },
                    "503": {
                        "description": "Service Unavailable",
                        "schema": {
                            "$ref": "#/definitions/api.ErrorEnvelope"
                        }
                    }
                }
            }
        },
        "/api/v1/auth/google/start": {
            "get": {
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "auth"
                ],
                "summary": "Start Google OAuth consent flow",
                "responses": {
                    "302": {
                        "description": "Redirect to Google consent screen",
                        "schema": {
                            "type": "string"
                        }
                    },
                    "503": {
                        "description": "Service Unavailable",
                        "schema": {
                            "$ref": "#/definitions/api.ErrorEnvelope"
                        }
                    }
                }
            }
        },
        "/api/v1/buildings": {
            "get": {
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "buildings"
                ],
                "summary": "List campus buildings",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/api.BuildingsResponse"
                        }
                    },
                    "503": {
                        "description": "Service Unavailable",
                        "schema": {
                            "$ref": "#/definitions/api.ErrorEnvelope"
                        }
                    }
                }
            }
        },
        "/api/v1/docs/openapi.json": {
            "get": {
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "docs"
                ],
                "summary": "Get Swagger specification",
                "responses": {
                    "200": {
                        "description": "Swagger JSON document",
                        "schema": {
                            "type": "string"
                        }
                    }
                }
            }
        },
        "/api/v1/health": {
            "get": {
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "health"
                ],
                "summary": "Get API health status",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/api.HealthResponse"
                        }
                    }
                }
            }
        },
        "/api/v1/rooms": {
            "get": {
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "rooms"
                ],
                "summary": "List rooms with current and next events",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Building code or ID",
                        "name": "building",
                        "in": "query"
                    },
                    {
                        "type": "string",
                        "description": "Room type",
                        "name": "type",
                        "in": "query"
                    },
                    {
                        "type": "string",
                        "description": "Room status (available|occupied|upcoming|maintenance)",
                        "name": "status",
                        "in": "query"
                    },
                    {
                        "type": "integer",
                        "description": "Minimum capacity",
                        "name": "capacity_min",
                        "in": "query"
                    },
                    {
                        "type": "integer",
                        "description": "Maximum capacity",
                        "name": "capacity_max",
                        "in": "query"
                    },
                    {
                        "type": "string",
                        "description": "Sort field (name|capacity|status)",
                        "name": "sort",
                        "in": "query"
                    },
                    {
                        "type": "string",
                        "description": "Sort order (asc|desc)",
                        "name": "order",
                        "in": "query"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/api.RoomsListResponse"
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "$ref": "#/definitions/api.ErrorEnvelope"
                        }
                    },
                    "503": {
                        "description": "Service Unavailable",
                        "schema": {
                            "$ref": "#/definitions/api.ErrorEnvelope"
                        }
                    }
                }
            }
        },
        "/api/v1/rooms/{code}": {
            "get": {
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "rooms"
                ],
                "summary": "Get room detail and today's schedule",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Room code",
                        "name": "code",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/api.RoomDetailResponse"
                        }
                    },
                    "404": {
                        "description": "Not Found",
                        "schema": {
                            "$ref": "#/definitions/api.ErrorEnvelope"
                        }
                    },
                    "503": {
                        "description": "Service Unavailable",
                        "schema": {
                            "$ref": "#/definitions/api.ErrorEnvelope"
                        }
                    }
                }
            }
        },
        "/api/v1/rooms/{code}/schedule": {
            "get": {
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "rooms"
                ],
                "summary": "Get room schedule for a time period",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Room code",
                        "name": "code",
                        "in": "path",
                        "required": true
                    },
                    {
                        "type": "string",
                        "description": "Start date-time (RFC3339)",
                        "name": "start",
                        "in": "query",
                        "required": true
                    },
                    {
                        "type": "string",
                        "description": "End date-time (RFC3339)",
                        "name": "end",
                        "in": "query",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/api.RoomScheduleResponse"
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "$ref": "#/definitions/api.ErrorEnvelope"
                        }
                    },
                    "404": {
                        "description": "Not Found",
                        "schema": {
                            "$ref": "#/definitions/api.ErrorEnvelope"
                        }
                    },
                    "503": {
                        "description": "Service Unavailable",
                        "schema": {
                            "$ref": "#/definitions/api.ErrorEnvelope"
                        }
                    }
                }
            }
        }
    },
    "definitions": {
        "api.BuildingResponse": {
            "type": "object",
            "properties": {
                "address": {
                    "type": "string"
                },
                "floors": {
                    "type": "array",
                    "items": {
                        "type": "integer"
                    }
                },
                "id": {
                    "type": "string"
                },
                "name": {
                    "type": "string"
                }
            }
        },
        "api.BuildingsResponse": {
            "type": "object",
            "properties": {
                "buildings": {
                    "type": "array",
                    "items": {
                        "$ref": "#/definitions/api.BuildingResponse"
                    }
                },
                "timestamp": {
                    "type": "string"
                }
            }
        },
        "api.ErrorEnvelope": {
            "type": "object",
            "properties": {
                "error": {
                    "$ref": "#/definitions/api.ErrorResponse"
                }
            }
        },
        "api.ErrorResponse": {
            "type": "object",
            "properties": {
                "code": {
                    "type": "string"
                },
                "message": {
                    "type": "string"
                },
                "timestamp": {
                    "type": "string"
                }
            }
        },
        "api.EventResponse": {
            "type": "object",
            "properties": {
                "end": {
                    "type": "string"
                },
                "organizer": {
                    "type": "string"
                },
                "start": {
                    "type": "string"
                },
                "title": {
                    "type": "string"
                }
            }
        },
        "api.HealthResponse": {
            "type": "object",
            "properties": {
                "google_admin_api_connected": {
                    "type": "boolean"
                },
                "google_calendar_api_connected": {
                    "type": "boolean"
                },
                "last_sync": {
                    "type": "string"
                },
                "response_time_ms": {
                    "type": "integer"
                },
                "status": {
                    "type": "string"
                },
                "version": {
                    "type": "string"
                }
            }
        },
        "api.PeriodResponse": {
            "type": "object",
            "properties": {
                "end": {
                    "type": "string"
                },
                "start": {
                    "type": "string"
                }
            }
        },
        "api.RoomDetailResponse": {
            "type": "object",
            "properties": {
                "building": {
                    "type": "string"
                },
                "capacity": {
                    "type": "integer"
                },
                "code": {
                    "type": "string"
                },
                "current_event": {
                    "$ref": "#/definitions/api.EventResponse"
                },
                "floor": {
                    "type": "integer"
                },
                "name": {
                    "type": "string"
                },
                "next_event": {
                    "$ref": "#/definitions/api.EventResponse"
                },
                "resource_email": {
                    "type": "string"
                },
                "schedule_today": {
                    "type": "array",
                    "items": {
                        "$ref": "#/definitions/api.EventResponse"
                    }
                },
                "status": {
                    "type": "string"
                },
                "type": {
                    "type": "string"
                }
            }
        },
        "api.RoomResponse": {
            "type": "object",
            "properties": {
                "building": {
                    "type": "string"
                },
                "capacity": {
                    "type": "integer"
                },
                "code": {
                    "type": "string"
                },
                "current_event": {
                    "$ref": "#/definitions/api.EventResponse"
                },
                "floor": {
                    "type": "integer"
                },
                "name": {
                    "type": "string"
                },
                "next_event": {
                    "$ref": "#/definitions/api.EventResponse"
                },
                "resource_email": {
                    "type": "string"
                },
                "status": {
                    "type": "string"
                },
                "type": {
                    "type": "string"
                }
            }
        },
        "api.RoomScheduleResponse": {
            "type": "object",
            "properties": {
                "events": {
                    "type": "array",
                    "items": {
                        "$ref": "#/definitions/api.EventResponse"
                    }
                },
                "period": {
                    "$ref": "#/definitions/api.PeriodResponse"
                },
                "room_code": {
                    "type": "string"
                }
            }
        },
        "api.RoomsListResponse": {
            "type": "object",
            "properties": {
                "count": {
                    "type": "integer"
                },
                "filters": {
                    "type": "object",
                    "additionalProperties": true
                },
                "rooms": {
                    "type": "array",
                    "items": {
                        "$ref": "#/definitions/api.RoomResponse"
                    }
                },
                "timestamp": {
                    "type": "string"
                }
            }
        }
    }
}