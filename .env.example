# OAuth 2.0 Web Server Flow (recommended)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8080/api/v1/auth/google/callback
GOOGLE_OAUTH_SCOPES=https://www.googleapis.com/auth/admin.directory.resource.calendar.readonly,https://www.googleapis.com/auth/calendar.readonly
GOOGLE_OAUTH_REFRESH_TOKEN_FILE=.secrets/google_oauth_refresh_token.json

# Admin SDK runtime options (optional)
GOOGLE_ADMIN_BASE_URL=
GOOGLE_ADMIN_CUSTOMER=my_customer
GOOGLE_ADMIN_PAGE_SIZE=100
GOOGLE_ADMIN_TIMEOUT=10s

# Calendar runtime options (optional)
GOOGLE_CALENDAR_BASE_URL=
GOOGLE_CALENDAR_PAGE_SIZE=250
GOOGLE_CALENDAR_TIMEOUT=10s

# Legacy/fallback auth options (optional)
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_SERVICE_ACCOUNT_JSON_BASE64=
GOOGLE_SERVICE_ACCOUNT_FILE=
GOOGLE_ADMIN_IMPERSONATED_USER=
GOOGLE_ADMIN_BEARER_TOKEN=
